{
  "name": "scoring",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev --workspace backend\" \"npm:dev --workspace frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "check:encoding": "node scripts/check-encoding.mjs",
    "build": "npm run build --workspace frontend",
    "smoke": "node scripts/smoke.mjs",
    "smoke:extractor": "node scripts/smoke-analysis.mjs",
    "smoke:analysis": "node scripts/smoke-analysis.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "^1.59.1"
  }
}
