{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TenderFacts",
  "type": "object",
  "required": [
    "document_package",
    "tender_facts",
    "confidence_flags",
    "notes"
  ],
  "properties": {
    "document_package": {
      "type": "object",
      "required": [
        "run_id",
        "source_documents"
      ],
      "properties": {
        "run_id": {
          "type": "string"
        },
        "source_documents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "path"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "kind": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "tender_facts": {
      "type": "object",
      "properties": {
        "customer": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject": {
          "type": [
            "string",
            "null"
          ]
        },
        "deadline": {
          "type": [
            "string",
            "null"
          ]
        },
        "procurement_stage": {
          "type": [
            "string",
            "null"
          ]
        },
        "procurement_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "selection_criteria": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "type"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "price",
                  "non_price"
                ]
              },
              "source": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "notes": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "requirements_without_weight": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "is_blocker": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "source": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "notes": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "comments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "confidence_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "reason"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
